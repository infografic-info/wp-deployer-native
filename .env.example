# Arquivos de ambiente por stage (não versionar valores reais):
#   .env            — valores locais / desenvolvimento (base)
#   .env.production — sobrescreve o base para produção
#   .env.staging    — sobrescreve o base para staging
# O stage é detectado automaticamente pelo argumento do dep (ex: dep deploy production)
# ou pela variável DEPLOY_ENV=production.

# ----------------------------------------------------------------------------
# Tipo de projeto e stack de produção
# ----------------------------------------------------------------------------
# native | bedrock
PROJECT_TYPE=native
# easyengine
PROD_STACK=easyengine

# ----------------------------------------------------------------------------
# Pacote de deploy (infografic/wp-deployer-core)
# ----------------------------------------------------------------------------
DEPLOY_PACKAGE_NAME=infografic/wp-deployer-core
DEPLOY_PACKAGE_VERSION=0.2.0
DEPLOY_TEMPLATES_VERSION=0.2.0

# ----------------------------------------------------------------------------
# WordPress bootstrap local (usado por .ddev/commands/web/install-wp-if-needed)
# ----------------------------------------------------------------------------
WP_TITLE="WP Deployer"
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change-me
WP_ADMIN_EMAIL=admin@example.com
WP_TIMEZONE=America/Sao_Paulo
WP_LANG=pt_BR
# Prefixo das tabelas do banco (deixar vazio para manter o padrão do wp-config.php)
WP_DB_PREFIX=

# ----------------------------------------------------------------------------
# Deploy / provisionamento (Deployer) — não versionar valores reais
# ----------------------------------------------------------------------------
PROD_IP=0.0.0.0
PROD_PORT=2232
PROD_DOMAIN=example.com
STAGING_IP=0.0.0.0
STAGING_PORT=2232
STAGING_DOMAIN=staging.example.com

# EasyEngine management host SSH (porta 22 padrão)
MGMT_USER=root
# IP do mgmt host para staging em deploy local (CI usa 10.0.0.1 por padrão)
STAGING_MGMT_IP=10.0.0.1

# ----------------------------------------------------------------------------
# EasyEngine — provisionamento (ee:provision / ee:site:create)
# ----------------------------------------------------------------------------
# Versão do PHP a usar no container do site (padrão: 8.3)
EE_PHP_VERSION=8.3
# Forçar banco de dados local no container EasyEngine (true | false)
EE_LOCAL_DB=false

# Banco de dados de PRODUÇÃO — usado por ee:site:create e provision:generate-shared-env
# Deixar em branco para banco gerenciado pelo EasyEngine
PROD_DB_NAME=''
PROD_DB_USER=''
PROD_DB_PASSWORD=''
PROD_DB_HOST=''
PROD_DB_PREFIX='wp_'

# ----------------------------------------------------------------------------
# Backblaze B2 — backup remoto via Duplicati
# ----------------------------------------------------------------------------
B2_APPLICATION_KEY=""
B2_APPLICATION_KEY_ID=""
