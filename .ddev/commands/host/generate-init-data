#!/bin/bash
## Description: Export database and uploads to init/data for production deployment
## Usage: generate-init-data
## Example: ddev generate-init-data

set -euo pipefail

DATA_DIR="$DDEV_APPROOT/init/data"
mkdir -p "$DATA_DIR"

echo "==> Exporting database..."
ddev exec mysqldump -u root -proot db > "$DATA_DIR/db.sql"
gzip -c "$DATA_DIR/db.sql" > "$DATA_DIR/db.sql.gz"
echo "    Saved: init/data/db.sql"
echo "    Saved: init/data/db.sql.gz"

echo "==> Exporting uploads..."
tar -czf "$DATA_DIR/uploads.tar.gz" -C "$DDEV_APPROOT" web/wp-content/uploads
echo "    Saved: init/data/uploads.tar.gz"

WEBP_EXPRESS_DIR="$DDEV_APPROOT/web/wp-content/webp-express"
if [[ -d "$WEBP_EXPRESS_DIR" ]]; then
	echo "==> Exporting webp-express..."
	tar -czf "$DATA_DIR/webp-express.tar.gz" -C "$DDEV_APPROOT" web/wp-content/webp-express
	echo "    Saved: init/data/webp-express.tar.gz"
else
	echo "==> webp-express not found in wp-content, skipping..."
fi

echo ""
echo "Init data generation complete. Files ready for production deployment via Deployer."
